{
  "name": "cherryteam",
  "version": "0.1.0",
  "description": "Ops-first multi-agent runtime with tool calling, vision input, routing, approvals, and bounded execution loops.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": "./dist/index.js",
  "bin": {
    "cherryteam": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "tsx --test test/*.test.ts",
    "check": "npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai-agent",
    "multi-agent",
    "tool-calling",
    "vision",
    "qwen",
    "vllm",
    "openai-compatible"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "24.13.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  }
}
